{
  "compilerOptions": {
    "target": "ES2020",
    "lib": ["ES2020", "DOM"],

    "module": "ESNext",
    "moduleResolution": "Bundler",

    "declaration": true,
    "declarationMap": true,

    "outDir": "dist",
    "rootDir": "src",

    "strict": true,
    "skipLibCheck": true,

    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,

    "resolveJsonModule": true,
    "isolatedModules": true
  },

  "include": ["src"],
  "exclude": ["node_modules", "dist", "tests"]
}